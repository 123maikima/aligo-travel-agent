# LLM configuration
LLM_PROVIDER=doubao
LLM_API_KEY=replace-me
LLM_MODEL_NAME=doubao-seed-1-6-251015
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=8192

# Optional tiered LLM profiles. Empty values fall back to the default LLM_* profile.
LLM_FAST_PROVIDER=
LLM_FAST_API_KEY=
LLM_FAST_MODEL_NAME=
LLM_FAST_BASE_URL=
LLM_FAST_TEMPERATURE=0.3
LLM_FAST_MAX_TOKENS=2048
LLM_REASONING_PROVIDER=
LLM_REASONING_API_KEY=
LLM_REASONING_MODEL_NAME=
LLM_REASONING_BASE_URL=
LLM_REASONING_TEMPERATURE=0.5
LLM_REASONING_MAX_TOKENS=8192

# Agent -> model tier routing: default / fast / reasoning
LLM_TIER_DEFAULT=default
LLM_TIER_INTENTION_AGENT=reasoning
LLM_TIER_ITINERARY_PLANNING=reasoning
LLM_TIER_RAG_KNOWLEDGE=reasoning
LLM_TIER_EVENT_COLLECTION=fast
LLM_TIER_PREFERENCE=fast
LLM_TIER_MEMORY_QUERY=fast
LLM_TIER_INFORMATION_QUERY=fast
LLM_TIER_MEMORY_SUMMARY=fast

# RAG / Embedding
RAG_EMBEDDING_MODEL=data/models/bge-m3
RAG_DOCUMENTS_DIR=data/documents
RAG_RETRIEVAL_MODE=hybrid
RAG_DENSE_TOP_K=10
RAG_SPARSE_TOP_K=10
RAG_FINAL_TOP_K=3
RAG_RRF_K=60

# Redis
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# PostgreSQL
POSTGRES_ENABLED=true
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=travel_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SSLMODE=disable
POSTGRES_CONNECT_TIMEOUT=5

# Web API / JWT
API_JWT_SECRET=replace-me
API_JWT_ALGORITHM=HS256
API_JWT_ISSUER=travel-agent
API_ACCESS_TOKEN_TTL_MINUTES=720
API_REQUIRE_AUTH=true

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# Observability
OBSERVABILITY_ENABLED=true
OBSERVABILITY_TRACE_DIR=data/traces
OBSERVABILITY_EVENT_LOG=data/traces/events.jsonl
OBSERVABILITY_METRICS_LOG=data/traces/metrics.jsonl
OBSERVABILITY_MAX_FIELD_CHARS=1200
